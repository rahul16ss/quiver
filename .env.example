# ─── LLM Provider (Ollama Cloud) ─────────────────────────────────────
# Get your API key at https://ollama.com
# The same key works for both LLM completions and Pro search/scrape.
#
# Other models on Ollama Cloud:
#   LLM_MODEL_NAME=deepseek-v4-pro:cloud
#   LLM_MODEL_NAME=kimi-k2.7-code:cloud
#
# For local Ollama:
#   LLM_API_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL_NAME=qwen2.5-coder:7b
#   LLM_API_KEY=
LLM_API_BASE_URL=https://ollama.com/v1
LLM_MODEL_NAME=glm-5.2:cloud
LLM_API_KEY=

# Ollama Pro API (same key as LLM_API_KEY)
OLLAMA_API_KEY=

# ─── Search & Scrape Fallback ────────────────────────────────────────
# Parallel.ai key (used when Ollama Pro is unavailable)
# Get your key at https://parallel.ai
PARALLEL_API_KEY=

# ─── Browser Control ─────────────────────────────────────────────────
# Set to false to show the browser window (for manual sign-in, etc.)
BROWSER_HEADLESS=true

# ─── Security Gate ───────────────────────────────────────────────────
# Comma-separated tools requiring approval before execution.
# Empty = fully autonomous (no y/N prompts)
# Default: run_command,write_file,replace_content,browser_control,create_tool
REQUIRE_APPROVAL_FOR=run_command,write_file,replace_content,browser_control,create_tool

# ─── Limits ──────────────────────────────────────────────────────────
# Maximum action iterations per turn (default: 10000)
QUIVER_MAX_LOOPS=10000
# Maximum estimated tokens before auto-trimming (default: 120000)
QUIVER_MAX_CONTEXT_TOKENS=120000

# ─── Session Logging ─────────────────────────────────────────────────
# Set to 0 to disable session logging
# QUIVER_SESSION_LOG=1
# Max chars per event field (default: 512)
QUIVER_SESSION_LOG_MAX_CHARS=512

# ─── GitHub ──────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Context7 Documentation Search ────────────────────────────────────
CONTEXT7_API_KEY=

# ─── SSRF Protection ─────────────────────────────────────────────────
# Block navigation/scraping to private/internal IPs (default: enabled)
# Set to 0 to disable (allows localhost, 10.x, 192.168.x, etc.)
QUIVER_BLOCK_PRIVATE_IPS=1