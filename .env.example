# ─── LLM Provider (Ollama Cloud) ─────────────────────────────────────
# Get your API key at https://ollama.com
# The same key works for both LLM completions and Pro search/scrape.
#
# Other models on Ollama Cloud:
#   LLM_MODEL_NAME=deepseek-v4-pro:cloud
#   LLM_MODEL_NAME=kimi-k2.7-code:cloud
#
# For local Ollama:
#   LLM_API_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL_NAME=qwen2.5-coder:7b
#   LLM_API_KEY=
LLM_API_BASE_URL=https://ollama.com/v1
LLM_MODEL_NAME=glm-5.2:cloud

# Ollama Pro API (same key as LLM_API_KEY)
OLLAMA_API_KEY=

# ─── Parallel.ai Web APIs ─────────────────────────────────────────────
# Powers: web_search, scrape_url, deep_research, find_all, entity_search
# Get your key at https://platform.parallel.ai
PARALLEL_API_KEY=

# ─── Browser Control (optional override) ────────────────────────────
# The browser_control tool manages headless mode per-call automatically.
# It passes headless: false for login/auth flows and headless: true for scraping.
# Only set this if you want to force a global default for all browser actions.
# BROWSER_HEADLESS=true

# ─── Security Gate ───────────────────────────────────────────────────
# Comma-separated tools requiring approval before execution.
# Empty = fully autonomous (no y/N prompts)
# Default: run_command,write_file,replace_content,browser_control,create_tool
REQUIRE_APPROVAL_FOR=run_command,write_file,replace_content,browser_control,create_tool

# ─── Limits ──────────────────────────────────────────────────────────
# Max context tokens before auto-trimming old messages.
# GLM 5.2 supports 1M tokens — leave ~100K headroom for model output (max 131K).
QUIVER_MAX_CONTEXT_TOKENS=900000

# ─── Session Logging ─────────────────────────────────────────────────
# Set to 0 to disable session logging (logs are written once at session end,
# so there is no per-event disk cost).
# QUIVER_SESSION_LOG=1

# ─── GitHub ──────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Cloud Sync (folder-based, any provider) ───────────────────────────
# Quiver syncs memory/ and .sessions/ to a local folder that any cloud
# sync app can back up: Google Drive, OneDrive, Dropbox, iCloud, etc.
#
# No OAuth, no API keys — just files in a folder your cloud app syncs.
#
# Auto-detection looks for:
#   ~/Google Drive/  ~/OneDrive/  ~/Dropbox/  ~/Library/CloudStorage/
#
# To override with a custom path:
# QUIVER_CLOUD_SYNC_PATH=/path/to/your/synced/folder

# ─── SSRF Protection ─────────────────────────────────────────────────
# Block navigation/scraping to private/internal IPs (default: enabled)
# Set to 0 to disable (allows localhost, 10.x, 192.168.x, etc.)
QUIVER_BLOCK_PRIVATE_IPS=1