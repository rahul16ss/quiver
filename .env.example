# ─── Quiver configuration ─────────────────────────────────────────────
# These are the only environment variables Quiver reads from .env.
# Secrets (API keys) may also be stored in the OS keychain instead of here.
#
# Single-key model (US-1.3): one OLLAMA_API_KEY powers the primary LLM, the
# Ollama adapter, and the vision adapter. LLM_API_KEY, VISION_MODEL_API_KEY,
# and CONTEXT7_API_KEY are retired and must not be used.

# ─── Core LLM ─────────────────────────────────────────────────────────
LLM_API_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
# LLM_MODEL_NAME is source-controlled in src/config.ts (default: glm-5.2:cloud).
# Uncomment to override the primary model:
# LLM_MODEL_NAME=

# ─── Vision fallback ──────────────────────────────────────────────────
# Routes image/video inputs to a multimodal model via Ollama.
# Install: ollama pull gemma3:4b  (or your preferred multimodal model)
# VISION_MODEL_NAME is source-controlled in src/config.ts (default: gemma3:4b).
# Uncomment to override, or set to an empty string to disable vision:
# VISION_MODEL_NAME=
VISION_MODEL_BASE_URL=http://localhost:11434/v1

# ─── Approvals & limits ───────────────────────────────────────────────
# Comma-separated tools requiring approval. Empty = fully autonomous.
REQUIRE_APPROVAL_FOR=run_command,write_file,replace_content,browser_control,create_tool

# YOLO mode — bypass ALL approval gates (tool-level + command risk classifier).
# Off by default. Enable with /yolo command at runtime or set to 1 here.
# WARNING: The agent will execute ANY tool or command without asking.
QUIVER_YOLO=0
# Leave headroom for output.
QUIVER_MAX_CONTEXT_TOKENS=120000

# ─── Browser ──────────────────────────────────────────────────────────
# Set to false to show the browser window (for manual sign-in).
BROWSER_HEADLESS=true

# ─── Session logging ──────────────────────────────────────────────────
# Set to 0 to disable session logging.
QUIVER_SESSION_LOG=1
QUIVER_SESSION_LOG_MAX_CHARS=512

# ─── Web APIs (optional) ──────────────────────────────────────────────
# Powers: web_search, scrape_url, deep_research, find_all, entity_search.
# Get your key at https://platform.parallel.ai
PARALLEL_API_KEY=

# ─── GitHub (optional — developers only) ──────────────────────────────
# Only needed for GitHub tooling (issues, PRs, repos).
GITHUB_TOKEN=

# ─── MCP (Model Context Protocol) ─────────────────────────────────────
# MCP servers are configured in .quiver/mcp.json (not .env).
# See .quiver/mcp.example.json for a sample config.
# MCP tools appear as mcp_<server>_<tool> in the tool list.
# Use /mcp to see connected servers.
