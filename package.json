{
  "name": "quiver",
  "version": "1.0.0",
  "description": "Quiver: Open harness for open models — self-evolving coding and research agent for the terminal.",
  "author": "rahul16ss",
  "license": "Apache-2.0",
  "type": "module",
  "main": "ui/main.ts",
  "bin": {
    "quiver": "./bin/quiver.js"
  },
  "scripts": {
    "start": "npx tsx src/cli.ts",
    "gui": "npx electron .",
    "test": "npx tsx tests/run_tests.ts",
    "dist": "electron-builder --mac --win --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.quiver.app",
    "productName": "Quiver",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "ui/**/*",
      "src/**/*",
      "bin/**/*",
      "node_modules/tsx/**/*",
      "node_modules/esbuild/**/*",
      "node_modules/get-tsconfig/**/*",
      "node_modules/resolve-pkg-maps/**/*",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      ".env.example"
    ],
    "extraResources": [
      {
        "from": "src",
        "to": "src"
      },
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "node_modules/tsx",
        "to": "node_modules/tsx"
      },
      {
        "from": "node_modules/esbuild",
        "to": "node_modules/esbuild"
      },
      {
        "from": "node_modules/get-tsconfig",
        "to": "node_modules/get-tsconfig"
      },
      {
        "from": "node_modules/resolve-pkg-maps",
        "to": "node_modules/resolve-pkg-maps"
      },
      {
        "from": "node_modules/picocolors",
        "to": "node_modules/picocolors"
      },
      {
        "from": "node_modules/zod",
        "to": "node_modules/zod"
      },
      {
        "from": "node_modules/dotenv",
        "to": "node_modules/dotenv"
      },
      {
        "from": "node_modules/fastest-levenshtein",
        "to": "node_modules/fastest-levenshtein"
      },
      {
        "from": "node_modules/html-to-text",
        "to": "node_modules/html-to-text"
      },
      {
        "from": "node_modules/cheerio",
        "to": "node_modules/cheerio"
      },
      {
        "from": "node_modules/puppeteer",
        "to": "node_modules/puppeteer"
      },
      {
        "from": "node_modules/puppeteer-core",
        "to": "node_modules/puppeteer-core"
      },
      {
        "from": "node_modules/@puppeteer/browsers",
        "to": "node_modules/@puppeteer/browsers"
      },
      {
        "from": "node_modules/chromium-bidi",
        "to": "node_modules/chromium-bidi"
      },
      {
        "from": "node_modules/devtools-protocol",
        "to": "node_modules/devtools-protocol"
      },
      {
        "from": "node_modules/lilconfig",
        "to": "node_modules/lilconfig"
      },
      {
        "from": "node_modules/typed-query-selector",
        "to": "node_modules/typed-query-selector"
      },
      {
        "from": "node_modules/ws",
        "to": "node_modules/ws"
      },
      {
        "from": "tsconfig.json",
        "to": "tsconfig.json"
      },
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "ui/renderer/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "ui/renderer/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "ui/renderer/icon.png"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fastest-levenshtein": "^1.0.16",
    "picocolors": "^1.1.1",
    "puppeteer": "^25.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
