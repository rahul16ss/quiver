{
  "name": "quiver",
  "version": "1.0.0",
  "description": "Quiver: A self-evolving agent harness for autonomous coding and research in the terminal.",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "quiver": "./bin/quiver.js"
  },
  "scripts": {
    "start": "npx tsx src/cli.ts",
    "gui": "npx electron ui/main.ts",
    "dashboard": "bun src/dashboard.ts",
    "dashboard:node": "node --experimental-ffi --allow-ffi src/dashboard.ts",
    "goal": "npx tsx src/goal.ts",
    "test": "npx tsx tests/run_tests.ts",
    "design:lint": "npx -p @google/design.md designmd lint DESIGN.md",
    "dist": "electron-builder --mac --win --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.quiver.app",
    "productName": "Quiver",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "ui/**/*",
      "src/**/*",
      "bin/**/*",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      ".env.example"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "ui/renderer/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "ui/renderer/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development",
      "icon": "ui/renderer/icon.png"
    }
  },
  "dependencies": {
    "@opentui/core": "^0.4.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "fastest-levenshtein": "^1.0.16",
    "html-to-text": "^10.0.0",
    "picocolors": "^1.1.1",
    "puppeteer": "^25.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.11.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
